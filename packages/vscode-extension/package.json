{
    "name": "promptsonar",
    "displayName": "PromptSonar",
    "description": "Static scanner for prompt injection (OWASP LLM01), API key leaks & jailbreaks in code. Local, fast, no LLM calls.",
    "version": "0.1.0",
    "icon": "icon.png",
    "keywords": [
        "prompt",
        "security",
        "injection",
        "llm",
        "owasp",
        "scanner",
        "linter",
        "ai"
    ],
    "publisher": "meghal-promptsonar",
    "repository": {
        "type": "git",
        "url": "https://github.com/raj-promptsonar/promptsonar.git"
    },
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "Linters",
        "Machine Learning"
    ],
    "activationEvents": [
        "onLanguage:python",
        "onLanguage:typescript",
        "onLanguage:javascript",
        "onLanguage:go",
        "onLanguage:java",
        "onLanguage:rust",
        "onLanguage:csharp"
    ],
    "main": "./dist/client/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "promptsonar.compress",
                "title": "PromptSonar: Compress with LLMLingua"
            }
        ],
        "configuration": {
            "type": "object",
            "title": "PromptSonar",
            "properties": {
                "promptsonar.enable": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable/disable PromptSonar"
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -b",
        "watch": "tsc -b -w",
        "package": "vsce package"
    },
    "dependencies": {
        "core": "file:../core/core-1.0.0.tgz",
        "vscode-languageclient": "^9.0.1",
        "vscode-languageserver": "^9.0.1",
        "vscode-languageserver-textdocument": "^1.0.11",
        "vscode-uri": "^3.0.8"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "@types/vscode": "^1.80.0",
        "typescript": "^5.0.0"
    }
}