{
    "name": "promptsonar",
    "displayName": "PromptSonar",
    "description": "Static scanner for prompt injection (OWASP LLM01), API key leaks & jailbreaks in code. Local, fast, no LLM calls.",
    "version": "1.0.21",
    "icon": "icon.png",
    "keywords": [
        "prompt",
        "security",
        "injection",
        "llm",
        "owasp",
        "scanner",
        "linter",
        "ai"
    ],
    "publisher": "promptsonar-tools",
    "repository": {
        "type": "git",
        "url": "https://github.com/meghal86/promptsonar.git"
    },
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "Linters",
        "Machine Learning"
    ],
    "main": "./dist/client/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "promptsonar.compress",
                "title": "PromptSonar: Compress with LLMLingua"
            },
            {
                "command": "promptsonar.runScan",
                "title": "PromptSonar: Run Health Check",
                "icon": "$(play)"
            },
            {
                "command": "promptsonar.scanWorkspace",
                "title": "PromptSonar: Scan Entire Workspace",
                "icon": "$(shield)"
            }
        ],
        "menus": {
            "editor/title": [
                {
                    "command": "promptsonar.runScan",
                    "group": "navigation"
                }
            ],
            "view/title": [
                {
                    "command": "promptsonar.scanWorkspace",
                    "when": "view == promptsonar-explorer",
                    "group": "navigation"
                }
            ]
        },
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "promptsonar-sidebar",
                    "title": "PromptSonar",
                    "icon": "icon.png"
                }
            ]
        },
        "views": {
            "promptsonar-sidebar": [
                {
                    "id": "promptsonar-explorer",
                    "name": "Prompt Analysis",
                    "icon": "icon.png"
                }
            ]
        },
        "configuration": {
            "type": "object",
            "title": "PromptSonar",
            "properties": {
                "promptsonar.enable": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable/disable PromptSonar"
                },
                "promptsonar.enableCodeLens": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable/disable 'Run Health Check' CodeLenses above detected prompts"
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "node esbuild.js --production",
        "watch": "node esbuild.js --watch",
        "package": "vsce package --no-dependencies",
        "pretest": "npm run compile"
    },
    "dependencies": {
        "core": "file:../core/core-1.0.1.tgz",
        "vscode-languageclient": "^9.0.1",
        "vscode-languageserver": "^9.0.1",
        "vscode-languageserver-textdocument": "^1.0.11",
        "vscode-uri": "^3.0.8"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "@types/vscode": "^1.80.0",
        "@vitest/coverage-v8": "^4.0.18",
        "esbuild": "^0.27.3",
        "typescript": "^5.0.0",
        "vitest": "^4.0.18"
    }
}